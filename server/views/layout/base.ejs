<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="<%= typeof description !== 'undefined' ? description : 'Personal journal & portfolio' %>">
    <meta name="theme-color" content="#0a0907">
    <link rel="manifest" href="/manifest.json">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Qraynix' %>">
    <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : '' %>">
    <meta property="og:type" content="website">

    <title>
        <%= typeof title !=='undefined' ? title : 'Qraynix' %>
    </title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">

    <!-- Compiled SCSS -->
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>
    <!-- Rune Background Decoration -->
    <div class="rune-bg" id="rune-bg"></div>

    <%- include('../partials/header') %>

        <main class="page-content">
            <%- body %>
        </main>

        <%- include('../partials/footer') %>

            <!-- Scroll to Top -->
            <button class="scroll-top" id="scroll-top" aria-label="Scroll to top">ᚨ</button>

            <!-- Public JS -->
            <script src="/js/main.js"></script>
            <script>
                window.__AI_CHAT_CONFIG__ = {
                    enabled: <%- JSON.stringify(typeof settings !== 'undefined' ? settings.ai_chat_enabled !== 'false' : true) %>,
                    botName: <%- JSON.stringify(typeof settings !== 'undefined' && settings.ai_chat_bot_name ? settings.ai_chat_bot_name : 'Site Bot') %>,
                    ownerName: <%- JSON.stringify(typeof settings !== 'undefined' && settings.ai_chat_owner_name ? settings.ai_chat_owner_name : ((typeof settings !== 'undefined' && settings.site_title) ? settings.site_title : 'Site Owner')) %>,
                    disclaimer: <%- JSON.stringify(typeof settings !== 'undefined' && settings.ai_chat_disclaimer ? settings.ai_chat_disclaimer : '') %>
                };
            </script>
            <script src="/js/aiChatWidget.js"></script>
</body>

</html>