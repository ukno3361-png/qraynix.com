<%# EJS Partial: entryCard — reusable card for entry listings %>
    <% const RUNES='ᚠᚢᚦᚨᚱᚲᚷᚹᚺᚾᛁᛃᛇᛈᛉᛊᛏᛒᛖᛗᛚᛜᛞᛟ' ; %>
        <% const rawCover=String(entry.cover_image || '').replace(/\\/g, '/').trim(); %>
            <% const normalizedCover=rawCover
                ? (rawCover.startsWith('http://') || rawCover.startsWith('https://')
                    ? rawCover
                    : (rawCover.startsWith('/uploads/')
                        ? rawCover
                        : (rawCover.startsWith('/image/') || rawCover.startsWith('/audio/') || rawCover.startsWith('/video/')
                            ? `/uploads${rawCover}`
                            : (rawCover.startsWith('uploads/') ? `/${rawCover}` : `/${rawCover.replace(/^\/+/, '')}`))))
                : ''; %>
        <a href="/entry/<%= entry.slug %>" class="entry-card fade-in">
            <div class="entry-cover-wrap">
                <% if (normalizedCover) { %>
                    <img src="<%= normalizedCover %>" alt="<%= entry.title %>" class="entry-cover" loading="lazy">
                    <% } else { %>
                        <div class="entry-cover-placeholder" aria-hidden="true">ᛟ</div>
                        <% } %>
            </div>
                    <span class="entry-rune">
                        <%= RUNES[entry.id % RUNES.length] %>
                    </span>
                    <div class="entry-body">
                        <h3 class="entry-title">
                            <%= entry.title %>
                        </h3>
                        <% if (entry.excerpt) { %>
                            <p class="entry-excerpt">
                                <%= entry.excerpt.substring(0, 160) %>
                            </p>
                            <% } %>
                                <div class="tags-row">
                                    <% (entry.tags || []).forEach(tag=> { %>
                                        <span class="tag-chip">
                                            <%= tag.name %>
                                        </span>
                                        <% }) %>
                                </div>
                                <div class="entry-meta">
                                    <span class="entry-date">
                                        <%= typeof formatRunicDate==='function' ? formatRunicDate(entry.published_at ||
                                            entry.created_at) : '' %>
                                    </span>
                                    <% if (entry.read_time) { %><span>~<%= entry.read_time %> min read</span>
                                        <% } %>
                                            <% if (entry.mood) { %><span>
                                                    <%= entry.mood %>
                                                </span>
                                                <% } %>
                                </div>
                    </div>
        </a>