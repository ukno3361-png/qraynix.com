<%# Header partial — sticky header with glowing rune logo and nav %>
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="site-logo">
                <span>
                    <%= typeof settings !=='undefined' && settings.site_title ? settings.site_title : 'Qraynix' %>
                </span>
            </a>

            <nav>
                <ul class="nav-links">
                    <li><a href="/" data-rune="ᚠ"
                            class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/' ? 'active' : '' %>">Home</a>
                    </li>
                    <% if (typeof settings==='undefined' || settings.show_timeline !=='false' ) { %>
                        <li><a href="/timeline" data-rune="ᛏ"
                                class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/timeline' ? 'active' : '' %>">Timeline</a>
                        </li>
                    <% } %>
                    <% if (typeof settings==='undefined' || settings.show_now !=='false' ) { %>
                        <li><a href="/now" data-rune="ᚾ"
                                class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/now' ? 'active' : '' %>">Now</a>
                        </li>
                    <% } %>
                    <% if (typeof settings==='undefined' || settings.show_music !=='false' ) { %>
                        <li><a href="/music" data-rune="ᛗ"
                                class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/music' ? 'active' : '' %>">Music</a>
                        </li>
                    <% } %>
                    <% if (typeof settings==='undefined' || settings.show_entertainment !=='false' ) { %>
                        <li><a href="/entertainment" data-rune="ᛊ"
                                class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/entertainment' ? 'active' : '' %>">Entertainment</a>
                        </li>
                    <% } %>
                    <li><a href="/thought-flash" data-rune="ᛃ"
                            class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/thought-flash' ? 'active' : '' %>">Thought Flash</a>
                    </li>

                    <%# "More" dropdown for secondary pages %>
                    <li class="nav-more-wrap">
                        <button class="nav-link nav-more-btn" data-rune="ᛜ" type="button" aria-expanded="false">More ▾</button>
                        <ul class="nav-more-dropdown">
                            <% if (typeof settings==='undefined' || settings.show_habits !=='false' ) { %>
                                <li><a href="/habit-tracker"
                                    class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/habit-tracker' ? 'active' : '' %>">Habits</a>
                                </li>
                            <% } %>
                            <% if (typeof settings==='undefined' || settings.show_future !=='false' ) { %>
                                <li><a href="/future"
                                    class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/future' ? 'active' : '' %>">Future</a>
                                </li>
                            <% } %>
                            <% if (typeof settings==='undefined' || settings.show_livecam !=='false' ) { %>
                                <li><a href="/live-cam"
                                    class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/live-cam' ? 'active' : '' %>">Live Cam</a>
                                </li>
                            <% } %>
                            <% if (typeof settings==='undefined' || settings.show_health !=='false' ) { %>
                                <li><a href="/health"
                                    class="nav-link <%= typeof currentPath !== 'undefined' && currentPath === '/health' ? 'active' : '' %>">Health</a>
                                </li>
                            <% } %>
                            <% if (typeof currentUser !=='undefined' && currentUser) { %>
                                <li><a href="/admin" class="nav-link">Dashboard</a></li>
                            <% } else { %>
                                <li><a href="/login" class="nav-link">Login</a></li>
                            <% } %>
                        </ul>
                    </li>
                </ul>
            </nav>

            <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle navigation">☰</button>
        </div>
    </header>